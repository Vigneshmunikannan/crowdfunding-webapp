# MongoDB (Atlas connection string)
MONGO_URI=mongodb+srv://USER:PASSWORD@cluster.example.mongodb.net/feedback?retryWrites=true&w=majority

# Admin dashboard (plain text in .env only — use strong unique values; prefer bcrypt + DB user table in larger systems)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change_me_to_a_long_random_secret

# JWT signing secret — minimum 32 characters; generate with: openssl rand -base64 48
JWT_SECRET=replace_with_at_least_32_random_characters
